{
  "$schema": "https://railway.app/v1.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["go_1_18"]
        },
        "build": {
          "cmds": ["go build -o libretaxi libretaxi.go"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "./libretaxi",
    "restartPolicyType": "ON_FAILURE"
  }
}

